# AI News Monitor — Шаблон переменных окружения
# Скопируй в .env и заполни реальные значения:  cp .env.example .env
# НИКОГДА не коммить .env с реальными данными!
#
# ⚠️  Этот модуль мигрируется в SPRUT (gateway/services/news_monitor/).
#     Этот .env используется только для standalone-режима.

# ============================================
# Telegram Bot
# ============================================
# Создать бота: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=CHANGE_ME_telegram_bot_token
# Узнать свой ID: https://t.me/userinfobot
TELEGRAM_OWNER_ID=CHANGE_ME_your_telegram_id

# ============================================
# API Security
# ============================================
# Secret key for protected endpoints (POST /api/collect)
API_SECRET_KEY=CHANGE_ME_random_secret_key
# Allowed CORS origins (comma-separated)
CORS_ORIGINS=["http://localhost:3000"]

# ============================================
# Сборщик новостей
# ============================================
# Интервал сбора новостей в часах (рекомендуется 4)
COLLECT_INTERVAL_HOURS=4
